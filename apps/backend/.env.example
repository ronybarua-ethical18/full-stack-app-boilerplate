# Display name for emails, Swagger, and server-driven copy (match NEXT_PUBLIC_APP_NAME in apps/web)
APP_NAME=Full Stack App Starter Pack

# Optional public API URL for Swagger "servers" (no trailing slash), e.g. https://api.example.com
# API_PUBLIC_URL=

# Public URL of the Next.js app (used in email links; no trailing slash)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here

# OAuth Configuration (for future use)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

GLOBAL_PREFIX=api/v1
PORT=8000